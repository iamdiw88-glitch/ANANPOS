// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// === ENUMS ===

enum MovementType {
  PURCHASE_IN
  SALE_OUT
  RETURN_IN
  ADJUST
  DAMAGE_OUT
}

enum RefType {
  SALE
  PURCHASE
  RETURN
  ADJUSTMENT
  DAMAGE
}

enum UserRole {
  OWNER
  CASHIER
  STAFF
}

enum CustomerType {
  CASH
  CREDIT
}

enum PriceTier {
  RETAIL
  CONTRACTOR
}

enum SaleStatus {
  PAID
  UNPAID
  PARTIAL
  VOID
}

enum DocType {
  RECEIPT
  TAX_INVOICE
}

enum PaymentType {
  CASH
  CREDIT
  PARTIAL
}

enum InvoiceStatus {
  OPEN
  PARTIAL
  PAID
}

enum PaymentMethod {
  CASH
  TRANSFER
  CHEQUE
}

enum DeliveryStatus {
  PENDING
  IN_TRANSIT
  DELIVERED
  FAILED
}

enum PurchaseStatus {
  PENDING
  RECEIVED
  CANCELLED
}

enum ReturnReason {
  DAMAGED
  WRONG_ITEM
  CUSTOMER_RETURN
}

enum RefundMethod {
  CASH
  CREDIT_NOTE
}

// === MASTER DATA ===

model Category {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  sortOrder Int       @default(0)
  isActive  Boolean   @default(true)
  products  Product[]
}

model Unit {
  id           Int           @id @default(autoincrement())
  name         String        @unique
  abbreviation String?
  baseProducts Product[]     @relation("BaseUnit")
  productUnits ProductUnit[]
}

model Supplier {
  id        Int        @id @default(autoincrement())
  code      String     @unique
  name      String
  phone     String?
  address   String?
  taxId     String?
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  purchases Purchase[]
}

// === PRODUCT & UOM ===

model Product {
  id             Int             @id @default(autoincrement())
  code           String          @unique
  name           String
  description    String?
  categoryId     Int
  baseUnitId     Int
  reorderPoint   Float           @default(0)
  isStockItem    Boolean         @default(true)
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  category       Category        @relation(fields: [categoryId], references: [id])
  baseUnit       Unit            @relation("BaseUnit", fields: [baseUnitId], references: [id])
  productUnits   ProductUnit[]
  stockMovements StockMovement[]
  stockBalance   StockBalance?
  saleItems      SaleItem[]
  purchaseItems  PurchaseItem[]
  returnItems    ReturnItem[]
}

model ProductUnit {
  id             Int     @id @default(autoincrement())
  productId      Int
  unitId         Int
  conversionRate Float
  price          Float
  contractorPrice Float?
  isDefaultSale  Boolean @default(false)
  isActive       Boolean @default(true)
  barcode        String? @unique

  product        Product @relation(fields: [productId], references: [id])
  unit           Unit    @relation(fields: [unitId], references: [id])
  saleItems      SaleItem[]
  purchaseItems  PurchaseItem[]
  returnItems    ReturnItem[]

  @@unique([productId, unitId])
}

// === STOCK ===

model StockBalance {
  productId      Int     @id
  quantityOnHand Float   @default(0)

  product        Product @relation(fields: [productId], references: [id])
}

model StockMovement {
  id           Int          @id @default(autoincrement())
  productId    Int
  movementType MovementType
  quantityBase Float
  unitCost     Float        @default(0)
  refType      RefType
  refId        Int?
  note         String?
  createdById  Int
  createdAt    DateTime     @default(now())

  product      Product      @relation(fields: [productId], references: [id])
  createdBy    User         @relation(fields: [createdById], references: [id])

  @@index([productId])
  @@index([createdAt])
}

// === USERS ===

model User {
  id             Int             @id @default(autoincrement())
  name           String
  role           UserRole        @default(CASHIER)
  pinHash        String
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())

  stockMovements StockMovement[]
  salesCreated   Sale[]          @relation("SaleCreatedBy")
  salesVoided    Sale[]          @relation("SaleVoidedBy")
  invoices       Invoice[]
  payments       Payment[]
  deliveries     Delivery[]
  purchases      Purchase[]
  returns        Return[]
}

// === CUSTOMERS ===

model Customer {
  id             Int          @id @default(autoincrement())
  code           String       @unique
  name           String
  phone          String?
  address        String?
  taxId          String?
  type           CustomerType @default(CASH)
  creditLimit    Float        @default(0)
  creditTermDays Int          @default(0)
  priceTier      PriceTier    @default(RETAIL)
  balance        Float        @default(0)
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  sales          Sale[]
  invoices       Invoice[]
  payments       Payment[]
  deliveries     Delivery[]
  returns        Return[]

  @@index([name])
  @@index([phone])
}

// === SALES ===

model Sale {
  id             Int         @id @default(autoincrement())
  billNo         String      @unique
  customerId     Int?
  saleDate       DateTime    @default(now())
  subtotal       Float
  discountAmount Float       @default(0)
  vatRate        Float       @default(0)
  vatAmount      Float       @default(0)
  grandTotal     Float
  paymentType    PaymentType
  paidAmount     Float       @default(0)
  status         SaleStatus  @default(UNPAID)
  docType        DocType     @default(RECEIPT)
  voidReason     String?
  voidedById     Int?
  voidedAt       DateTime?
  createdById    Int
  createdAt      DateTime    @default(now())

  customer       Customer?   @relation(fields: [customerId], references: [id])
  createdBy      User        @relation("SaleCreatedBy", fields: [createdById], references: [id])
  voidedBy       User?       @relation("SaleVoidedBy", fields: [voidedById], references: [id])
  items          SaleItem[]
  deliveries     Delivery[]
  returns        Return[]
  invoiceSales   InvoiceSale[]

  @@index([saleDate])
  @@index([customerId])
  @@index([status])
}

model SaleItem {
  id             Int         @id @default(autoincrement())
  saleId         Int
  productId      Int
  productUnitId  Int
  quantity       Float
  quantityBase   Float
  unitPrice      Float
  discountAmount Float       @default(0)
  lineTotal      Float

  sale           Sale        @relation(fields: [saleId], references: [id])
  product        Product     @relation(fields: [productId], references: [id])
  productUnit    ProductUnit @relation(fields: [productUnitId], references: [id])
}

// === AR (Accounts Receivable) ===

model Invoice {
  id          Int           @id @default(autoincrement())
  invoiceNo   String        @unique
  customerId  Int
  invoiceDate DateTime      @default(now())
  dueDate     DateTime
  totalAmount Float
  paidAmount  Float         @default(0)
  balance     Float
  status      InvoiceStatus @default(OPEN)
  createdById Int
  createdAt   DateTime      @default(now())

  customer    Customer      @relation(fields: [customerId], references: [id])
  createdBy   User          @relation(fields: [createdById], references: [id])
  invoiceSales InvoiceSale[]
  payments    Payment[]

  @@index([invoiceDate])
  @@index([status])
  @@index([customerId])
}

model InvoiceSale {
  invoiceId   Int
  saleId      Int
  amount      Float

  invoice     Invoice @relation(fields: [invoiceId], references: [id])
  sale        Sale    @relation(fields: [saleId], references: [id])

  @@id([invoiceId, saleId])
}

model Payment {
  id          Int           @id @default(autoincrement())
  paymentNo   String        @unique
  customerId  Int
  invoiceId   Int?
  amount      Float
  method      PaymentMethod
  paymentDate DateTime      @default(now())
  reference   String?
  note        String?
  createdById Int
  createdAt   DateTime      @default(now())

  customer    Customer      @relation(fields: [customerId], references: [id])
  invoice     Invoice?      @relation(fields: [invoiceId], references: [id])
  createdBy   User          @relation(fields: [createdById], references: [id])

  @@index([paymentDate])
  @@index([customerId])
}

// === DELIVERY ===

model Delivery {
  id              Int            @id @default(autoincrement())
  saleId          Int
  customerId      Int
  deliveryAddress String
  scheduledDate   DateTime?
  status          DeliveryStatus @default(PENDING)
  driverName      String?
  vehicle         String?
  deliveredAt     DateTime?
  isCOD           Boolean        @default(false)
  note            String?
  createdById     Int
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  sale            Sale           @relation(fields: [saleId], references: [id])
  customer        Customer       @relation(fields: [customerId], references: [id])
  createdBy       User           @relation(fields: [createdById], references: [id])

  @@index([scheduledDate])
  @@index([status])
}

// === PURCHASES ===

model Purchase {
  id           Int            @id @default(autoincrement())
  purchaseNo   String         @unique
  supplierId   Int
  purchaseDate DateTime       @default(now())
  subtotal     Float
  total        Float
  status       PurchaseStatus @default(PENDING)
  note         String?
  createdById  Int
  createdAt    DateTime       @default(now())

  supplier     Supplier       @relation(fields: [supplierId], references: [id])
  createdBy    User           @relation(fields: [createdById], references: [id])
  items        PurchaseItem[]

  @@index([purchaseDate])
}

model PurchaseItem {
  id            Int         @id @default(autoincrement())
  purchaseId    Int
  productId     Int
  productUnitId Int
  quantity      Float
  unitCost      Float
  lineTotal     Float

  purchase      Purchase    @relation(fields: [purchaseId], references: [id])
  product       Product     @relation(fields: [productId], references: [id])
  productUnit   ProductUnit @relation(fields: [productUnitId], references: [id])
}

// === RETURNS ===

model Return {
  id             Int          @id @default(autoincrement())
  returnNo       String       @unique
  originalSaleId Int
  customerId     Int?
  returnDate     DateTime     @default(now())
  reason         ReturnReason
  totalRefund    Float
  refundMethod   RefundMethod
  note           String?
  createdById    Int
  createdAt      DateTime     @default(now())

  originalSale   Sale         @relation(fields: [originalSaleId], references: [id])
  customer       Customer?    @relation(fields: [customerId], references: [id])
  createdBy      User         @relation(fields: [createdById], references: [id])
  items          ReturnItem[]

  @@index([returnDate])
}

model ReturnItem {
  id            Int         @id @default(autoincrement())
  returnId      Int
  productId     Int
  productUnitId Int
  quantity      Float
  quantityBase  Float
  restock       Boolean
  unitPrice     Float
  lineTotal     Float

  returnRec     Return      @relation(fields: [returnId], references: [id])
  product       Product     @relation(fields: [productId], references: [id])
  productUnit   ProductUnit @relation(fields: [productUnitId], references: [id])
}

// === SETTINGS ===

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

